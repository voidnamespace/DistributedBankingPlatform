{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auth" }
        ]
      },

      "account-route": {
        "ClusterId": "account-cluster",
        "Match": {
          "Path": "/account/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/account" }
        ]
      },

      "transaction-route": {
        "ClusterId": "transaction-cluster",
        "Match": {
          "Path": "/transaction/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/transaction" }
        ]
      }
    },

    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "https://localhost:5001/"
          }
        }
      },

      "account-cluster": {
        "Destinations": {
          "account-service": {
            "Address": "https://localhost:7185/"
          }
        }
      },

      "transaction-cluster": {
        "Destinations": {
          "transaction-service": {
            "Address": "https://localhost:7090/"
          }
        }
      }
    }
  }
}